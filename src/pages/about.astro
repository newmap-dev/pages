---
import PageLayout from '../layouts/PageLayout.astro';
import { Content } from '../content/pages/about.md';
---

<PageLayout title="About">
  <div class="mx-auto max-w-3xl px-6 pt-24 md:pt-32 pb-24 md:pb-32">
    <p class="text-sm font-medium text-accent uppercase tracking-widest mb-4">About</p>
    <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-text-primary leading-[0.95] mb-6">
      Who we are
    </h1>
    <p class="text-xl text-text-secondary max-w-lg leading-relaxed mb-12">
      Engineers and designers who think getting lost in a building should not be normal.
    </p>

    <article class="prose-custom border-t border-border pt-12">
      <Content />
    </article>
  </div>
</PageLayout>
