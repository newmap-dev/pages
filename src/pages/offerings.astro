---
import PageLayout from '../layouts/PageLayout.astro';

const offeringFiles = import.meta.glob('../content/offerings/*.md', { eager: true });

const offerings = Object.entries(offeringFiles).map(([path, mod]: [string, any]) => {
  const slug = path.replace(/.*\/offerings\//, '').replace('.md', '');
  return {
    slug,
    ...mod.frontmatter,
  };
});
---

<PageLayout title="Offerings">
  <div class="mx-auto max-w-3xl px-6 pt-24 md:pt-32 pb-24 md:pb-32">
    <p class="text-sm font-medium text-accent uppercase tracking-widest mb-4">Offerings</p>
    <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-text-primary leading-[0.95] mb-6">
      How we work with partners
    </h1>
    <p class="text-xl text-text-secondary max-w-lg leading-relaxed mb-12">
      Flexible ways to work together, starting with pilots.
    </p>

    <div class="flex flex-col gap-6">
      {offerings.map((offering) => (
        <a
          href={`/offerings/${offering.slug}`}
          class="group block p-5 md:p-6 bg-surface border border-border rounded-2xl no-underline shadow-sm hover:shadow-md hover:border-accent/50 transition-all"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <h2 class="text-lg md:text-xl font-semibold text-text-primary group-hover:text-accent transition-colors">
                  {offering.title}
                </h2>
                {offering.status && (
                  <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium bg-bg text-text-secondary border border-border rounded-md">
                    {offering.status}
                  </span>
                )}
              </div>
              <p class="text-sm md:text-base text-text-secondary leading-relaxed">
                {offering.subtitle}
              </p>
            </div>
            <span class="text-accent text-xl shrink-0 mt-1 md:mt-2 transition-transform group-hover:translate-x-1">
              →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
