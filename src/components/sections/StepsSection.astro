---
interface Step {
  title: string;
  description: string;
}

const { steps, heading } = Astro.props as { steps: Step[]; heading?: string };
---

<section class="py-12 md:py-16">
  <div class="mx-auto max-w-5xl px-6">
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-text-primary mb-10">
        {heading}
      </h2>
    )}
    <div class="flex flex-col md:flex-row gap-0">
      {steps.map((step: Step, index: number) => (
        <div class="flex-1 py-6 md:py-0 md:px-8 relative">
          {index > 0 && (
            <div class="hidden md:block absolute left-0 top-0 bottom-0 w-px bg-border" />
          )}
          <span class="text-xs font-medium text-accent uppercase tracking-widest mb-3 block">
            {String(index + 1).padStart(2, '0')}
          </span>
          <h3 class="text-lg font-semibold text-text-primary mb-2">
            {step.title}
          </h3>
          <p class="text-base text-text-secondary leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
