---
const { heading, body } = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="max-w-2xl">
      {heading && (
        <h2 class="text-2xl md:text-3xl font-serif font-semibold tracking-tight text-text-primary mb-5">
          {heading}
        </h2>
      )}
      {body && (
        <p class="text-lg text-text-secondary leading-relaxed">
          {body}
        </p>
      )}
      <slot />
    </div>
  </div>
</section>
