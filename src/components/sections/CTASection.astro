---
const { heading, body, linkText, linkHref } = Astro.props;
---

<section class="py-16 md:py-24 border-t border-border">
  <div class="mx-auto max-w-5xl px-6">
    <div class="max-w-2xl">
      {heading && (
        <h2 class="text-3xl md:text-4xl font-serif font-semibold tracking-tight text-text-primary mb-4">
          {heading}
        </h2>
      )}
      {body && (
        <p class="text-lg text-text-secondary leading-relaxed mb-8">
          {body}
        </p>
      )}
      {linkText && linkHref && (
        <a
          href={linkHref}
          class="inline-block px-6 py-3 bg-accent text-white font-medium no-underline hover:bg-accent-hover transition-colors"
        >
          {linkText}
        </a>
      )}
    </div>
  </div>
</section>
