---
const { title, subtitle } = Astro.props;
---

<section class="pt-16 pb-12 md:pt-24 md:pb-16">
  <div class="mx-auto max-w-5xl px-6">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold tracking-tight text-text-primary leading-[0.95] mb-4">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-text-secondary max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>
</section>
