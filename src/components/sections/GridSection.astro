---
interface GridItem {
  title: string;
  description: string;
  href?: string;
}

const { items, heading } = Astro.props as { items: GridItem[]; heading?: string };
---

<section class="py-12 md:py-16">
  <div class="mx-auto max-w-5xl px-6">
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-text-primary mb-10">
        {heading}
      </h2>
    )}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {items.map((item: GridItem) => {
        const Wrapper = item.href ? 'a' : 'div';
        return (
          <Wrapper
            href={item.href}
            class={`group ${item.href ? 'no-underline cursor-pointer' : ''}`}
          >
            <h3 class={`text-lg font-semibold text-text-primary mb-2 ${item.href ? 'group-hover:text-accent' : ''} transition-colors duration-150`}>
              {item.title}
            </h3>
            <p class="text-base text-text-secondary leading-relaxed">
              {item.description}
            </p>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>
